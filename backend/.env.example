# Google Cloud — credentials are fully configured and Vertex AI is enabled
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# Service account key file — already created and downloaded
# Either set this, or run `gcloud auth application-default login` for ADC
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Neo4j AuraDB — fully provisioned cloud instance
# All three values are available in the AuraDB console under "Connection details"
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-auradb-password
